#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
long long int solver( int vals,int vale,int si, int ei,int m){
    vector <vector <int> > a(ei-si+1,vector<int>(m+1,0));
    long long int ans=0;
    a[0][vals]++;
    for(int i=1;i<ei-si;i++){
        for(int j=1;j<m+1;j++){
            a[i][j] = a[i-1][j-1];a[i][j]+=a[i-1][j];a[i][j] %= big;
            if(j+1 <= m) a[i][j]+=a[i-1][j+1];
            a[i][j] %= big;
        }
    }
    ans = a[ei-si-1][vale-1];ans+=a[ei-si-1][vale];ans%=big;
    if(vale != m) ans+=a[ei-si-1][vale+1];
    ans%=big;
    return ans;
}
int main(){
    int n,m;cin>>n>>m;
    vector <int> arr(n),n_zero;
    long long int ans=1;
    for(int i=0;i<n;i++) {cin>>arr[i];
    if(arr[i]!=0) {n_zero.push_back(i);
                  }}
    if(arr[0] == 0 && n_zero.size()>0){
        long long int count=0;
        for(int i=1;i<m+1;i++){
            count+=solver(i,arr[n_zero[0]],0,n_zero[0],m);
            count = count%big;
        }
        ans=ans*count;ans=ans%big;
    }
    if(arr[n-1]==0 && n_zero.size()>0){
        long long int count=0;
        for(int i=1;i<m+1;i++){
            count+=solver(arr[n_zero[n_zero.size()-1]],i,n_zero[n_zero.size()-1],n-1,m);
            count = count%big;
        }
        ans=ans*count;ans=ans%big;
    }
    if(n_zero.size()>0){
        long long int count=0;
        for(int j=0;j<n_zero.size()-1;j++){
            count=solver(arr[n_zero[j]],arr[n_zero[j+1]],n_zero[j],n_zero[j+1],m);
            ans=ans*count;ans=ans%big;
        }
    }
    else{
        long long int count=0;
        if(n>1){
        for(int i=1;i<m+1;i++){
            for(int j=1;j<m+1;j++){
                count+=solver(i,j,0,n-1,m);
                count = count%big;
            }
        }}
        else if(arr[0] == 0) count =m;
        else count =1;
        ans=ans*count;ans=ans%big;
    }
    cout<<ans<<endl;
}
