
#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;cin>>t;
    while(t--){
        int n, k;
    cin >> n >> k;

    if (k == n) {
        cout<<"YES"<<endl;
        for (int i = 1; i < n; i++) {
            cout << i << " ";
        }
        cout << 0 << endl;
        continue;
    }

    int ta = k ^ n;
    if (ta >= 1 && ta <= n - 1) {
        vector<int> a(n, 0);
        a[0] = 1;
        a[ta] = 1;
        cout<<"YES"<<endl;
        for (int i = 0; i < n; i++) {
            if (!a[i]) cout << i << " ";
        }
        cout << 0 << " " << ta << endl;
        continue;
    }
    int n1= -1, n2 = -1;
    for (int i = 1; i < n; i++) {
        int num = i ^ ta;
        if (num >= 1 && num <= n - 1 && num != i) {
            n1 = max(i, num);
            n2 = min(i, num);
        }
    }
    if(n1>0 && n2>0){
        vector<int> a(n, 0);
        a[0] = 1;
        a[n1] = 1;
        a[n2]=1;
        cout<<"YES"<<endl;
        for (int i = 0; i < n; i++) {
            if (!a[i]) cout << i << " ";
        }
        cout << 0 << " " << n2 <<" "<<n1<< endl;
        continue;
    }   
    cout<<"NO"<<endl;
    }
}
