#include <bits/stdc++.h>
using namespace std;
int main(){
    int n,q;cin>>n>>q;
    int arr[n];
    long long int csum[n];
    cin>>arr[0];csum[0]=arr[0];
    for(int i=1;i<n;i++){
        cin>>arr[i];
        csum[i] = csum[i-1]+arr[i];
    }
    while(q--){
        int a,b;cin>>a>>b;
        long long int ans = csum[b-1] - csum[a-1] + arr[a-1];
        cout<<ans<<endl;
    }
}
