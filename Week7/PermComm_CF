        }
        sort(values.begin(),values.end());
        int visit=0,num=0,val_idx=0;
        int in=0,filled=values.size();
        bool ans=true;
        if(values.size()){ in=values[0].second;num=values[0].first;visited[in]=1;
        while(true){
            if(b[index[in]-1]==-1) {
                if(ff[index[num]]==1) {ans=false;break;}
                b[index[in]-1] = index[num];ff[index[num]]=1;
                visited[index[in]]=1;
                                        in=index[in];num=index[num];filled++;
                                   if(filled == n) break;}
