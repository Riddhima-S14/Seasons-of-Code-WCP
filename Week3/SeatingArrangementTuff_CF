#include <bits/stdc++.h>
using namespace std;
long long int multiply ( int s,int num){
    long long int ans=0;
    while(s>0){
        ans+=num;
        s--;
    }
    return(ans);
}
int main(){
    int t;cin>>t;
    while(t--){
    int n,x,s;cin>>n>>x>>s;
    string p;
    cin>>p;
    long long int a = 0,seated=0,empty=x;
    for(int i=0;i<n;i++){
        if(p[i] == 'A') a++;
        if(p[i] == 'I' && empty>0){
            empty--;seated++;}
        else if (p[i] == 'A' && multiply(s,x-empty) == seated && empty>0){
            empty--;seated++;a--;
        }
        else if(p[i] == 'A' && seated <multiply(s,x)) seated++;
        else if (p[i] == 'E' && multiply(s,x-empty) > seated) seated ++;
        else if (p[i]=='E' && multiply(s,x-empty) == seated && empty>0){
            if(a>0) {empty--;seated++;a--;}
        }
    }
    cout<<seated<<endl;}
}
