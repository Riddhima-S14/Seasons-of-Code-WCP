#include <bits/stdc++.h>
using namespace std;
int main(){
    int n,t;cin>>n>>t;
    vector <int> arr(n);
    for(int i = 0;i<n;i++) cin>>arr[i];
    int a =0,b=0,maxi=0,len =0;
    int sum = 0;
    while(b<n && a<n){
        sum+= arr[b];
        if(sum<=t){
            len++;
            b++;
            maxi = max(maxi,len);
        }
        if(sum>t){
            sum-= arr[a];
            a++;
            len = b-a + 1;
            if (sum <=t) maxi = max(maxi,len);
            b++;
 
        }
    }
    cout<<maxi<<endl;
}
