#include <bits/stdc++.h>
using namespace std;
int main(){
    int n,q;cin>>n>>q;
    vector <int> arr(n,0),asked(n,0),nasked(n,0);
    vector <int> asum(n,0),msum(n,0),fin(n,0);
    for (int i=0;i<n;i++) cin>>arr[i];
    sort(arr.begin(),arr.end());
    while(q--){
        int l,r;cin>>l>>r;
        l--;r--;
        asked[r]++;
        if(l>0) nasked[l-1]++;
        asum[0]+=1;
        if(l>0) msum[0]++;
    }
    fin[0] = asum[0]-msum[0];
    for(int i=1;i<n;i++){
        asum[i] = asum[i-1]-asked[i-1];
        msum[i] = msum[i-1] - nasked[i-1];
        fin[i] = asum[i]-msum[i];
    }
    sort(fin.begin(),fin.end());
    long long int fsum=0;
    for(int i=0;i<n;i++){
        for(int j=0;j<fin[i];j++){
            fsum+= arr[i];
        }
    }
    cout<<fsum<<endl;
}
