#include <bits/stdc++.h>
using namespace std;
int main() {
    int t;cin>>t;
    while(t--){
        int n,k;cin>>n>>k;
        string s;cin>>s;
        vector<int>r(n,0),l(n,0);
        int cl=0,cr=0;
        if(s[0]=='R')r[0]==1;
        if(s[n-1]=='L') l[n-1]==1;
        for(int i=0;i<n;i++){
            if(s[i]=='R') cr++;
            else cl++;
        }
        if(k>n/2) cout<<-1<<endl;
        else{
            int count=0;
            for(int i=0;i<k;i++){
                if(s[i] == 'L') count++;
                if(s[n-1-i]=='R')count++;
            }
            cout<<count<<endl;
        }
    }
}
