#include <bits/stdc++.h>
using namespace std;
int main(){
    // freopen("input.txt", "r", stdin);
    // freopen("output.txt", "w", stdout);
    
        int n,sx,sy;cin>>n>>sx>>sy;
        int a1=0,a2=0,a3=0,a4=0,a5=0,a6=0,a7=0,a8=0;
        vector <vector<int> > house(n,vector <int> (2,0));
        for(int i=0;i<n;i++){
            cin>>house[i][0]>>house[i][1];
            if(house[i][0] > sx){
                if(house[i][1] > sy) a1++;
                else if (house[i][1] == sy) a5++;
                else a2++;
            }
            else if (house[i][0] == sx){
                if (house[i][1] > sy) a8++;
                else a6++;
            }
            else{
                if(house[i][1] > sy) a4++;
                else if (house[i][1] == sy) a7++;
                else a3++;
            }
        }
        int b1,b2,b3,b4;
        int ansx,ansy;
        b1 = a1+a5+a2;b2=a2+a3+a6;b3 = a3+a4+a7;b4 = a4+a1+a8;
        vector <int> v = {b1,b2,b3,b4};
        sort(v.begin(),v.end());
        int maxi = v[3];
        if(maxi == b1 ) {
            ansx = sx+1;
            ansy = sy;
        }
        else if(maxi == b2){
            ansx = sx;
            ansy = sy - 1;
        }
        else if(maxi == b3){
            ansx = sx-1;
            ansy = sy;
        }
        else{
            ansx = sx;
            ansy = sy+1;
        }
        cout<<maxi<<endl;
            cout<<ansx<<" "<<ansy<<endl;
    
}
