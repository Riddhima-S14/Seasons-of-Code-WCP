#include <bits/stdc++.h>
using namespace std;
int x(int n){
    if(n%2==0) return n;
    else return n+1;
}
int main(){
    int t;cin>>t;
    while(t--){
        int k; cin >> k;
        vector<int> v(k);
        for (int i=0;i<k;i++) cin >>v[i];
 
        vector<int> A(k), B(k);
        int c1 = 0, c23 = 0;
        for (int i = 0; i < k; i++) {
            if (v[i] == 1) c1++; else c23++;
            A[i] = c1 - c23;
        }
        int b = 0;
        for (int i = 0; i < k; i++) {
            b += (v[i] != 3) ? 1 : -1;
            B[i] = b;
        }
 
        vector<int> sufMax(k + 1,-1000000);
        for (int j = k - 2; j >= 0; j--)
            sufMax[j] = max(B[j], sufMax[j + 1]);
 
        bool ok = false;
        for (int i = 0; i <= k - 3; i++) {  
            if (A[i] >= 0 && sufMax[i + 1] >= B[i]) { ok = true; break; }
        }
 
        cout << (ok ? "YES" : "NO") << endl;
        
    }
}
