#include <bits/stdc++.h>
using namespace std;
int main(){
    int n;cin>>n;
    vector <int> arr(n);
    for(int i = 0;i<n;i++) cin>>arr[i];
    sort(arr.begin(),arr.end());
    int q;cin>>q;
    while(q--){
        int p;cin>>p;
        auto it = upper_bound(arr.begin(),arr.end(),p);
        int num = it-arr.begin();
        if (num > n) cout<<0;
        else cout<<num<<endl;
    }
}
