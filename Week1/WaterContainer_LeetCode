class Solution {
public:
    int maxArea(vector<int>& height) {
        int n = height.size();
        int l=0,r=n-1;
        int area=0;
        while(r>=l){
            area = max(area,abs(r-l)*min(height[r],height[l]));
            if(height[l]<height[r]){
                l++;
            }
            else r--;
        }
        return area;
    }
};
