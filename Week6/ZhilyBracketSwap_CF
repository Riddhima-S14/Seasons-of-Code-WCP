#include <bits/stdc++.h>
using namespace std;
int main() {
    int t;cin>>t;
    while(t--){
        int n;cin>>n;
        string s1,s2;
        cin>>s1>>s2;
        vector<int> a(n,0),b(n,0);
        if(s1[0]=='(') a[0]++;
        else {cout<<"No"<<endl;continue;}
        if(s2[0]=='(') b[0]++;
        else {cout<<"No"<<endl;continue;}
        for(int i=1;i<n;i++){
            if(s1[i]=='(') {a[i]=a[i-1]+1;}
            else a[i]=a[i-1]-1;
            if(s2[i]=='(') {b[i]=b[i-1]+1;}
            else b[i]=b[i-1]-1;
        }
        if(a[n-1]+b[n-1] !=0 ){
            cout<<"No"<<endl;continue;
        }
        bool ans=true;
        int asum=0,bsum=0;
        for(int i=0;i<n;i++){
            if(s1[i]==s2[i]){
                asum=(s1[i] == ')')?asum-1 :asum+1;
                bsum=(s2[i] == ')')?bsum-1 :bsum+1;
            }
            else{
            if(asum>bsum){
                asum--;
                bsum++;
            }
            else{
                asum++;bsum--;
            }}
            if(asum < 0 || bsum<0){
                ans=false;
            }
        }
        if(ans && asum==0 && bsum==0){
            cout<<"Yes"<<endl;
        }
        else{
            cout<<"No"<<endl;
        }
    }
}
