#include <bits/stdc++.h>
using namespace std;
long long int two(long long int x){
    long long int ans=1;
    ans*=x;ans*=x;
    return ans;
}
int main(){
    int t;cin>>t;
    while(t--){
        int n;cin>>n;
        long long int trips=0;
        for(long long int i=1;i<=n;i++){
            long long int possible = n/i;
            long long int yes=0;
            yes = two(possible);
            trips+=yes;
        }
        cout<<trips<<endl;
    }
}
