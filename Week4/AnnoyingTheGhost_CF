#include <bits/stdc++.h>
using namespace std;
int larger(vector<long long int> &arr,long long int value,int start){
    int index=start;
    for(int i=start;i<arr.size();i++){
        if (arr[i]<=value){ index=i;break;}
    }
    int temp=arr[index],moves=0;
    for(int i=index;i>start;i--){
        arr[i]=arr[i-1];
        moves++;
    }
    arr[start]=temp;
    return moves;
}
int main(){
    int t;cin>>t;
    while(t--){
        int n;cin>>n;
        vector<long long int>a(n),b(n);
        for(int i=0;i<n;i++)cin>>a[i];
        for(int i=0;i<n;i++)cin>>b[i];
        vector<long long int>copy(n);
        for(int i=0;i<n;i++) copy[i]=a[i];
        sort(copy.begin(),copy.end());
        bool ans=true;
        for(int i=0;i<n;i++){
            if(copy[i]>b[i]) ans=false;
        }
        if(ans){
            int moves=0;
        for(int i=0;i<n;i++){
            if(a[i]<=b[i]) continue;
            else{
                moves += larger(a,b[i],i);
            }
        }
           cout<<moves<<endl;
    }
        else cout<<-1<<endl;
    }
}
