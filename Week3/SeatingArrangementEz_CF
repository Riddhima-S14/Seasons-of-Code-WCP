#include <bits/stdc++.h>
using namespace std;
int main(){
    int t;cin>>t;
    while(t--){
    int n,x,s;cin>>n>>x>>s;
    string p;
    cin>>p;
    int a = 0,seated=0,empty=x;
    for(int i=0;i<n;i++){
        if(p[i] == 'A') a++;
        if(p[i] == 'I' && empty>0){
            empty--;seated++;}
        else if (p[i] == 'A' && (x-empty)*s == seated && empty>0){
            empty--;seated++;a--;
        }
        else if(p[i] == 'A' && seated < x*s) seated++;
        else if (p[i] == 'E' && (x-empty)*s > seated) seated ++;
        else if (p[i]=='E' && (x-empty)*s == seated && empty>0){
            if(a>0) {empty--;seated++;a--;}
        }
    }
    cout<<seated<<endl;}
}
