#include <bits/stdc++.h>
using namespace std;
int main(){
    int t;cin>>t;
    while(t--){
        int k;cin>>k;
        vector<int> v(k);
        int num=0,num1=0;
        for(int i=0;i<k;i++) {cin>>v[i];
                            if(v[i]>1) num++; 
                              if(v[i]>2) num1++;
                             }
        if(num>1 || num1>0) cout<<"YES"<<endl;
        else cout<<"NO"<<endl;
        
    }
}
