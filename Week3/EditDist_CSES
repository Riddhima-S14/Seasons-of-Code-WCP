#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
void solver(string s1, string s2, int n,int m){
    vector<vector<int> > v(n+1,vector<int> (m+1,0));
    for(int i=0;i<n+1;i++){
        v[i][0] = i;
    }
    for(int i=0;i<m+1;i++) v[0][i] = i;
    for(int i=1;i<n+1;i++){
        for(int j=1;j<m+1;j++){
            if(s1[i-1] == s2[j-1]) v[i][j]= v[max(i-1,0)][max(j-1,0)];
            else { v[i][j] = min(v[max(i-1,0)][j]+1,v[i][max(j-1,0)]+1);
            v[i][j] = min(v[i][j],v[max(i-1,0)][max(j-1,0)]+1);}
        }
    }
    cout<<v[n][m]<<endl;
}
int main(){
    string s1,s2;cin>>s1>>s2;
    solver(s1,s2,s1.length(),s2.length());
}
