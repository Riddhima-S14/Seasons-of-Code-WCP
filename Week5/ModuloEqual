#include <bits/stdc++.h>
using namespace std;
int main(){
    // freopen("input.txt", "r", stdin);
    // freopen("output.txt", "w", stdout);
    int n,m;cin>>n>>m;
    vector <int> a(n),b(n);
    for(int i=0;i<n;i++) cin>>a[i];
    for(int i=0;i<n;i++) cin>>b[i];
    sort(a.begin(),a.end());
    sort(b.begin(),b.end());
    int curr1=0,curr2=0;
    vector<vector<int> > c1(1,vector<int>(2,0)),c2(1,vector<int>(2,0));
    c1[0][0] = a[0];c1[0][1]++;c2[0][0] = b[0];c2[0][1]++;
    for(int i=1;i<n;i++){
        if(a[i-1]== a[i]){
            c1[curr1][1]++;
        }
        else{
            curr1++;
            vector<int> temp; temp.push_back(a[i]);temp.push_back(1);
            c1.push_back(temp);
        }
        if(b[i-1]== b[i]){
            c2[curr2][1]++;
        }
        else{
            curr2++;
            vector<int> temp; temp.push_back(b[i]);temp.push_back(1);
            c2.push_back(temp);
        }
    }
    int x = 0;
    vector<int> solve1,solve2;
    sort(c1.begin(),c1.end(),[](const vector<int> &a, const vector<int> &b){
        if(a[1] != b[1]) return a[1]>b[1];
        else return a[0] > b[0] ;
    });
    sort(c2.begin(),c2.end(),[](const vector<int> &a, const vector<int> &b){
        if(a[1] != b[1]) return a[1]>b[1];
        else return a[0] > b[0] ;
    });
    for(int i=0;i<c1.size();i++){
        if(c1[i][0] == c2[i][0]){
            continue;
        }
        else if(c1[i][0] != c2[i][0] ){
            while(i<c1.size() && c1[i][1] == c2[i][1] ){
                solve1.push_back(c1[i][0]);solve2.push_back(c2[i][0]);
                i++;
            }
            break;
        }
    }
    if(solve1.size()){
        if (solve1[0] < solve2[0]) x = solve2[0] - solve1[0];
        else if (solve1.size()==1) x = m-solve1[0]+solve2[0];
        else{
            x = m-solve1[0]+solve2[0];
            if((solve1[1]+x)%m != solve2[1]){
                x = m - solve1[0] + solve2[solve2.size()-1];
            }
            else{
                x = min(x,m - solve1[0] + solve2[solve2.size()-1]);
                if((solve1[1]+x)%m != solve2[0]){
                    x = m-solve1[0]+solve2[0];
                }
            }
        }
    }
    cout<<x<<endl;
}
