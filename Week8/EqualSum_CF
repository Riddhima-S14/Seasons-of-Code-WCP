#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int t;cin>>t;int count=1;
    vector <vector<long long int> > v(0,vector<long long int> (3,0));
    while(count < t+1){
        int n;cin>>n;int arr[n];
        long long int sum=0;
        for(int i=0;i<n;i++){
            cin>>arr[i];sum+=arr[i];
        }
        for(int i=0;i<n;i++){
            vector<long long int> temp;
            temp.push_back(sum-arr[i]);temp.push_back(count);temp.push_back(i+1);
            v.push_back(temp);
        }
        count++;
    }
    sort(v.begin(),v.end(), [](const vector<long long int> &a,const vector<long long int> &b ){return a[0] < b[0] ; });
    for(int i=0;i<v.size()-1;i++){
        if(v[i][0] == v[i+1][0]){
            if(v[i][1] != v[i+1][1]){
                cout<<"YES"<<endl;
                cout<<v[i][1]<<" "<<v[i][2]<<endl;
                cout<<v[i+1][1]<<" "<<v[i+1][2]<<endl;
                return 0;
            }
        }
    }
    cout<<"NO"<<endl;
}
