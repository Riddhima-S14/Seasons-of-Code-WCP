#include <bits/stdc++.h>
using namespace std;
int main(){
    // freopen("input.txt", "r", stdin);
    // freopen("output.txt", "w", stdout);
    int t;cin>>t;
    while(t--){
        int x,y,k;cin>>x>>y>>k;
        long long int trades = 0;
        for(int i=0;i<k;i++){
            trades+=y;
        }
        trades+=k;trades--;
        if(trades%(x-1) != 0 ) trades = (trades/(x-1)) +1;
        else trades = trades/(x-1);
        trades+= k;
        cout<<trades<<endl;
    }
}
