#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
 
int main(){
    int t;cin>>t;
    while(t--){
        int n,k;cin>>n>>k;
        string s;cin>>s;
        vector<int> v(k,0);
        for(int i=0;i<n;i++){
            if(s[i]=='0') continue;
            else{
                v[i%k]+=1;
            }
        }
        bool ans = true;
        for(int i=0;i<k;i++){
            if(v[i]%2==1) ans=false;
        }
        if(ans) cout<<"YES"<<endl;
        else cout<<"NO"<<endl;
    }
}
