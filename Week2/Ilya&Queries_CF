#include <bits/stdc++.h>
using namespace std;
int main(){
    string s; cin>>s;
    int n = s.length();
    vector<int> arr(n-1,0),csum(n-1,0);
    for(int i=0;i<n-1;i++){
        if(s[i] == s[i+1]) arr[i]++;
        csum[0] = arr[0];
        if(i>0) csum[i] = csum[i-1] + arr[i];
    }
    int q; cin>>q;
    while(q--){
        int l,r;cin>>l>>r;l--;r--;
        int ans = csum[r-1] - csum[l] + arr[l] ;
        cout<< ans<<endl;
    }
}
