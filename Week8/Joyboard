#include <bits/stdc++.h>
using namespace std;
int main(){
    // freopen("input.txt", "r", stdin);
    // freopen("output.txt", "w", stdout);
    int t;cin>>t;
    while(t--){
        int n,m,k;cin>>n>>m>>k;
        long long int ans = 0;
        if (k>3) ans = 0;
        else if(k==1){
            ans = 1;
        }
        else if (k ==2){
            if(m<=n) ans = m;
            else{
                ans = n + (m/n)-1;
            }
        }
        else{
            if(m<=n) ans = 0;
            else{
                ans = m - (n + (m/n)-1);
            }
        }
        cout<<ans<<endl;
    }
}
