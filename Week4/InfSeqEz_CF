#include <bits/stdc++.h>
using namespace std;
int solver(long long int r,long long int n, const vector<int> &arr, const vector<int> &cu){
    if(r<=n) return arr[r-1];
    else if(r<=2*n+1) return cu[(r/2)-1];
    else{
        if(r/2 % 2 == 1) return cu[n-1]^(cu[max(int((n/2)-1),0)] *(n%2==0));
        else return solver(r/2,n,arr,cu)^cu[n-1]^(cu[max(int((n/2)-1),0)] *(n%2==0));
    }
}
int main(){
    int t;cin>>t;
    while(t--){
        long long int n,l,r;cin>>n>>l>>r;
        vector<int> arr(n,0);
        for(int i=0;i<n;i++) cin>>arr[i];
        vector<int> cu(n,0);cu[0]=arr[0];
        for(int i=1;i<n;i++){
            cu[i]=cu[i-1]^arr[i];
        }
        int ans = solver(r,n,arr,cu);
        cout<<ans<<endl;
    }
}
