#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
void solver(const vector <vector<int> > &v,int x, int n){
    vector <vector<int> > a(n,vector<int> (x+1,0));
    for(int i=0;i<x+1;i++){
        a[n-1][i] = (v[n-1][0]>i)?0:v[n-1][1];
    }
    for(int si=n-2;si>-1;si--){
    a[si][x]= max(v[si][1]+a[si+1][max(x-v[si][0],0)], a[si+1][x]);
    for(int i=0;i<x;i++){
        a[si][i] = (v[si][0]<=i)?max(v[si][1]+a[si+1][max(i-v[si][0],0)], a[si+1][i]):a[si+1][i];}}
    cout<<a[0][x]<<endl;
    
}
int main(){
    int n,x;cin>>n>>x;
    vector <vector<int> > v(n,vector<int> (2,0));
    for(int i=0;i<n;i++) cin>>v[i][0];
    for(int i=0;i<n;i++) cin>>v[i][1];
    solver(v,x,n);
}
