#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
void ans(int n,int x, const vector < int> &c, vector<long long int> &a){
    a[0]=1;
    for(int i=1;i<x+1;i++){
        for(int j=0;j<n;j++){
            if(i>=c[j]){
            a[i] += a[i-c[j]];
                a[i]=a[i]%big;}
        }
    }
    cout<<a[x]<<'\n';
}
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
    int n,x;cin>>n>>x;
    vector <int> arr(n);
    for(int i=0;i<n;i++) {cin>>arr[i];}
    vector <long long int> a(x+1,0);
    ans(n,x,arr,a);
}
