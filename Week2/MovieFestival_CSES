#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
int occ(int value, const vector<int> &v,int start){
    for(int i=start;i<v.size();i++){
        if (v[i]>= value) return i;
    }
    return -1;
}
int main(){
    int n;cin>>n;
    vector<pair<int,int> >movie(n);
    for(int i=0;i<n;i++){
        int a,b;cin>>a>>b;
        movie[i].first=a;movie[i].second=b;
    }
    sort(movie.begin(),movie.end(),[](const pair<int,int>&a,const pair<int,int>&b ){return a.second<b.second; });
    vector<int> start(n),end(n);
    for(int i=0;i<n;i++){
        start[i] = movie[i].first;
        end[i] = movie[i].second;
    }
    int count=1;
    int it= occ(end[0],start,1);
    while(it != -1){
        int index=it;
        count++;
        it=occ(end[it],start,1+it);
    }
    cout<<count<<endl;
}
