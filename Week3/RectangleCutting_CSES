#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
void solver(int a,int b){
    vector<vector<int> > v(a+1,vector<int> (b+1,1e6));
    for(int i=0;i<min(a,b)+1;i++){
        v[i][i]=0;
    }
    for(int i=1;i<a+1;i++){
        for(int j=1;j<b+1;j++){
            for(int k=1;k<i;k++){
                int temp = v[i-k][j]+v[k][j]+1;
                v[i][j]=min(v[i][j],temp);
            }
            for(int k=1;k<j;k++){
                int temp = v[i][j-k]+v[i][k]+1;
                v[i][j]=min(v[i][j],temp);
            }
        }
    }
    cout<<v[a][b]<<endl;
}
int main(){
    int a,b;cin>>a>>b;
    solver(a,b);
}
