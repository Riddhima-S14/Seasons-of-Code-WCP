class Solution {
public:
    int search(vector<int>& nums, int target) {
        int l=0, r = nums.size();
        while(r-l > 1){
            int mid = (r+l)/2;
            if ( target < nums[mid]){
                r = mid;
            }
            else l = mid;
        }
        if(nums[l] == target) return l;
        else return -1;
    }
};
