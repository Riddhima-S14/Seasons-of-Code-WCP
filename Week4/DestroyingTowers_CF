#include <bits/stdc++.h>
using namespace std;
int main(){
    int t;cin>>t;
    while(t--){
        int n;cin>>n;
        vector<int>arr(n);
        for(int i=0;i<n;i++)cin>>arr[i];
        int minel=1000;
        int sum=0;
        for(int i=0;i<n;i++){
            minel=min(minel,arr[i]);
            sum+=minel;
        }
        cout<<sum<<endl;
    }
}
