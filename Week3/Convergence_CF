#include <bits/stdc++.h>
using namespace std;
// freopen("input.txt", "r", stdin);
// freopen("output.txt", "w", stdout);
int main(){
    int t; cin>>t;
    while(t--){
        int n;cin>>n;
        vector <int> arr(n);
        for(int i=0;i<n;i++){
            cin>>arr[i];
        }
        sort(arr.begin(),arr.end());
        int mid = arr[n/2], times=0,smaller=0;
        for(int i=0;i<n;i++){
            if(arr[i] == arr[n/2]) times++;
            if(arr[i]<arr[n/2]) smaller++;
        }
        int calls = 0, total=n;
        calls+= min(n-times-smaller,smaller);
        calls+= total-times-2*calls;
        cout<<calls<<endl;
    }
}
