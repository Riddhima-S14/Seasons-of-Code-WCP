#include <bits/stdc++.h>
using namespace std;
int main(){
    int n,w;cin>>n>>w;
    int p=n;
    vector <int> weights(n), rweights(n);
    for(int i=0;i<n;i++){
        cin>>weights[i];
    }
    int count=n, r=0,i=0;
    sort(weights.begin(),weights.end());
    for(int i=0;i<n;i++) rweights[n-i-1] = weights[i];
    while(i<n && r<n && r < n-i-1){
        if(rweights[r]+ weights[i] <= w){
            count--; r++;i++;
        }
        else r++;
    }
    cout<<count<<endl;
}
