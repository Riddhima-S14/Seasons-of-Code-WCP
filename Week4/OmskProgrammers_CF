#include <bits/stdc++.h>
using namespace std;
long long int big = 998244353;
int main(){
    int t;cin>>t;
    while(t--){
        int a,b,x;cin>>a>>b>>x;
        int ans_max = abs(b-a),count=0;
        vector <int> pa,pb;
        while(a>0){
            pa.push_back(a);
            a/=x;
        }
        while(b>0){
            pb.push_back(b);
            b/=x;
        }
        pa.push_back(0);
        pb.push_back(0);
        for(int i=0;i<pa.size();i++){
            for (int j=0;j<pb.size();j++){
                ans_max=min(i+j+abs(pa[i]-pb[j]),ans_max);
            }
        }
        cout<<ans_max<<endl;
}
}
