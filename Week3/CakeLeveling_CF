#include <bits/stdc++.h>
using namespace std;
// freopen("input.txt", "r", stdin);
// freopen("output.txt", "w", stdout);
int main(){
    int t;cin>>t;
    while(t--){
        int n;cin>>n;
        vector <long long int> arr(n);
        for(int i=0;i<n;i++){
            cin>>arr[i];
        }
    long long int sum=0;
    int min_height = arr[0];
        for(int i=0;i<n;i++){
            sum+=arr[i];
            int possible = sum/(i+1);
            min_height = min(min_height,possible);
            cout<<min_height<<" ";
        }
        cout<<endl;
    }
}
