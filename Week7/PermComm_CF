                if(b[index[in]-1] == index[num]) {visit++;visited[index[in]]=1;
                                                  while (val_idx < values.size() && visited[values[val_idx].second]) {
                        val_idx++;
                    }
                                                 if (val_idx == values.size()) {
                        break;
                    }
                                                  else{
                                                     in = values[val_idx].second;
                                                    num = values[val_idx].first;
                                                      visited[in] = 1;
                                                 }}
                else{
                    ans=false;break;
                }
                                                
            }
            
        }}
        if(ans){
        set <int> assigned;
        for(int i=0;i<n;i++){
            assigned.insert(i+1);
        }
        for(int i=0;i<n;i++){
            if(b[i]>0) assigned.erase(b[i]);
        }
        for(int i =0;i<n;i++){
            if (b[i]==-1) {b[i] = *assigned.begin();
                           assigned.erase(assigned.begin());}
        }
            cout<<"YES"<<endl;
            for(int i=0;i<n;i++) cout<<b[i]<<" ";
            cout<<endl;}
        else cout<<"NO"<<endl;
        
    }
