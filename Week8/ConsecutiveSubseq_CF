#include <bits/stdc++.h>
using namespace std;
long long int big = 1e9 + 7;
void solver(int n, const vector<int> &v){
    int maxl=0,el=0;
    map <int,int> m;
    for(int i=0;i<n;i++){
        m[v[i]] = m[v[i]-1] + 1;
        if(m[v[i]]>maxl) el = v[i];
        maxl=max(m[v[i]],maxl);
    }
    int j=el-maxl+1;
    cout<<maxl<<endl;
    for(int i=0;i<n;i++){
        if(v[i] == j){cout<<i+1<<" ";
        j++;}
    }
    cout<<endl;
    
}
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);
        int n;cin>>n;
        vector<int> v(n);
        for(int i=0;i<n;i++) cin>>v[i];
        solver(n,v);
}
