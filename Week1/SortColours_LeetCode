class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n = nums.size();
        vector <int> a(3,0);
        for(int i=0;i<n;i++){
            a[nums[i]]++;
        }
        int i=0;
        while(i<n){
            if( i<a[0]) nums[i] = 0;
            else if ( i < a[1] + a[0]) nums[i] = 1;
            else nums[i] = 2;
            i++;
        }
    }
};
